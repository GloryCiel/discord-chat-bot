DISCORD_TOKEN=your_discord_bot_token
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=qwen/qwen3.6-27b
# AI_SYSTEM_PROMPT=You are a friendly Discord chatbot.

# Palworld GCP VM control
GCP_PROJECT_ID=your_gcp_project_id
GCP_ZONE=asia-northeast3-a
GCP_INSTANCE_NAME=your_instance_name
GCP_SERVICE_ACCOUNT_JSON_BASE64=base64_encoded_service_account_json
DISCORD_CONTROL_GUILD_ID=your_discord_server_id
# Leave both empty to allow every member of the configured Discord server.
DISCORD_CONTROL_USER_IDS=
DISCORD_CONTROL_ROLE_IDS=
